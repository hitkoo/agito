# Optional local Agito data dir override
AGITO_HOME=/absolute/path/to/.agito

# Copy this file to .env.local for development.
# These values are public build-time config and are safe to bundle into the app.

# agito-server base URL used by the desktop app
AGITO_PUBLIC_API_URL=http://localhost:8000

# Supabase desktop auth
AGITO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
AGITO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Optional password reset redirect URL used by Supabase email flows
AGITO_PUBLIC_AUTH_RESET_REDIRECT_URL=https://your-app-domain/reset-password
