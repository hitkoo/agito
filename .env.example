# Optional local Agito data dir override
AGITO_HOME=/absolute/path/to/.agito

# agito-server base URL
AGITO_API_URL=http://localhost:8000

# Supabase desktop auth
AGITO_SUPABASE_URL=https://your-project.supabase.co
AGITO_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional password reset redirect URL used by Supabase email flows
AGITO_AUTH_RESET_REDIRECT_URL=https://your-app-domain/reset-password
